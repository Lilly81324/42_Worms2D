{
  "transport": {
    "library": "socket.io",
    "path": "/socket.io/",
    "clientToServerEvent": "msgToServer",
    "serverToClientEvent": "msgToClient",
    "encoding": "JSON string payload on the game socket",
    "serverBroadcast": "The current EventSocket emits every msgToClient packet through server.emit, so packets are broadcast to all connected sockets rather than addressed to one player."
  },
  "sharedShapes": {
    "clientServerBase": {
      "lobbyId": 0,
      "userId": "user-uuid"
    },
    "serverClientBase": {
      "lobbyId": 0,
      "seq": [1]
    },
    "pointData": {
      "x": 0,
      "y": 0
    },
    "aimStateId": {
      "AimAngle": 0,
      "PianoPickPosition": 1,
      "PickPosition": 2,
      "SwitchTargetAngle": 3
    },
    "gameState": {
      "GAME_PENDING": 0,
      "GAME_LOADING": 1,
      "GAME_START": 2,
      "ROUND_START": 3,
      "TURN_START": 4,
      "PICK_WORM": 5,
      "MOVEMENT": 6,
      "AIMING": 7,
      "TURN_END": 8,
      "GAME_END": 9
    }
  },
